{
  "name": "pixuli-monorepo",
  "description": "Pixuli - 智能图片管理应用 Monorepo",
  "private": true,
  "scripts": {
    "build:packages": "pnpm --filter @pixuli/core --filter @pixuli/provider-gitee build",
    "dev:web": "pnpm -F pixuli-app dev:web",
    "dev:desktop": "pnpm -F pixuli-app dev:desktop",
    "dev:android": "pnpm -F pixuli-app dev:android",
    "run:android": "pnpm -F pixuli-app run:android",
    "build:web": "pnpm -F pixuli-app build:web",
    "build:desktop": "pnpm -F pixuli-app build:desktop",
    "build:android": "pnpm -F pixuli-app build:android:release",
    "build:android:debug": "pnpm -F pixuli-app build:android:debug",
    "build:android:sync": "pnpm -F pixuli-app build:android",
    "test": "vitest run",
    "lint": "eslint packages/core",
    "lint:boundaries": "pnpm lint",
    "check:types": "pnpm -F pixuli-app exec tsc",
    "check:desktop": "pnpm -F pixuli-app exec vite build --mode desktop",
    "smoke:web": "pnpm build:packages && pnpm test && pnpm build:web",
    "smoke:desktop": "pnpm smoke:web && pnpm check:types && pnpm check:desktop",
    "smoke:e2e": "playwright test e2e/smoke --project=chromium",
    "smoke": "pnpm smoke:desktop",
    "ci": "pnpm build:packages && pnpm lint:boundaries && pnpm test && pnpm build:web && pnpm check:types && pnpm check:desktop",
    "prepare": "husky"
  },
  "keywords": [
    "monorepo",
    "electron",
    "vite",
    "react",
    "typescript",
    "图片管理"
  ],
  "author": "trueLoving",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/react-native": "^12.8.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.5",
    "eslint": "^9.25.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.30.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["prettier --write"],
    "*.{css,scss,less}": ["prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
