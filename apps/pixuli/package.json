{
  "name": "pixuli-app",
  "productName": "Pixuli",
  "version": "2.0.0",
  "type": "module",
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://localhost:5173"
    }
  },
  "description": "Pixuli App - 智能图片管理应用（支持 Web 和 Desktop）",
  "main": "dist-electron/main/index.js",
  "homepage": "./",
  "scripts": {
    "build:packages": "pnpm --filter @pixuli/core --filter @pixuli/provider-gitee build",
    "dev:web": "pnpm build:packages && vite --mode web",
    "dev:desktop": "pnpm build:packages && vite --mode desktop",
    "build:vercel-api": "pnpm build:packages && esbuild api/gitee-proxy.entry.ts --bundle --platform=node --format=esm --outfile=api/gitee-proxy.js --banner:js=\"// Generated by build:vercel-api from gitee-proxy.entry.ts — do not edit\"",
    "build:web": "pnpm build:vercel-api && vite build --mode web",
    "build:desktop": "tsc && vite build --mode desktop && electron-builder",
    "dev:android": "node scripts/dev-android.mjs",
    "dev:android:server": "pnpm build:packages && vite --mode web --host 0.0.0.0 --port 5500",
    "run:android": "node scripts/run-android.mjs",
    "build:android": "CAPACITOR_NATIVE=1 CAPACITOR_SERVER_URL= pnpm run build:web && cap sync android",
    "build:android:debug": "pnpm run build:android && cd android && ./gradlew assembleDebug",
    "build:android:release": "pnpm run build:android && cd android && ./gradlew assembleRelease",
    "cap:sync": "cap sync android",
    "cap:android": "cap open android",
    "sync:brand": "node scripts/sync-brand-assets.mjs",
    "test": "vitest"
  },
  "keywords": ["electron", "vite", "react", "typescript", "图片管理"],
  "author": "trueLoving",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^7.6.6",
    "@capacitor/app": "^7.1.2",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/clipboard": "^7.0.4",
    "@capacitor/core": "^7.6.6",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/share": "^7.0.4",
    "@pixuli/core": "workspace:*",
    "@pixuli/provider-gitee": "workspace:*",
    "@pixuli/provider-github": "workspace:*",
    "@pixuli/ui": "workspace:*",
    "exifr": "^7.1.3",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.556.0",
    "octokit": "3.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.0.1",
    "react-router-dom": "^7.11.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.6",
    "@types/node": "^22.18.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.14",
    "electron": "^33.4.11",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.25.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.24",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.1.0"
  }
}
