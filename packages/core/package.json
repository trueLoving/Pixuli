{
  "name": "@pixuli/core",
  "version": "1.0.0",
  "description": "Pixuli core — shared types, platform adapters, utils, and plugin contracts",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "development": "./src/types/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./plugins": {
      "development": "./src/plugins/index.ts",
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./plugins/host": {
      "development": "./src/plugins/hostIntegration.ts",
      "types": "./dist/plugins/host.d.ts",
      "import": "./dist/plugins/host.js"
    },
    "./plugins/registry": {
      "development": "./src/plugins/registry.ts",
      "types": "./dist/plugins/registry.d.ts",
      "import": "./dist/plugins/registry.js"
    },
    "./platform": {
      "development": "./src/platform/index.ts",
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js"
    },
    "./utils": {
      "development": "./src/utils/index.ts",
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./locales": {
      "development": "./src/locales/index.ts",
      "types": "./dist/locales/index.d.ts",
      "import": "./dist/locales/index.js"
    },
    "./operation-log": {
      "development": "./src/operation-log/index.ts",
      "types": "./dist/operation-log/index.d.ts",
      "import": "./dist/operation-log/index.js"
    },
    "./sources": {
      "development": "./src/sources/index.ts",
      "types": "./dist/sources/index.d.ts",
      "import": "./dist/sources/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
