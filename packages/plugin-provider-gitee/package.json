{
  "name": "@pixuli/provider-gitee",
  "version": "1.0.0",
  "description": "Pixuli Gitee storage provider plugin",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "development": "./src/register.ts",
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./manifest": {
      "development": "./src/manifest.ts",
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@pixuli/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
